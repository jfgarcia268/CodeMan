{
  "name": "codeman-desktop",
  "version": "1.7.0",
  "description": "CodeMan desktop wrapper — opens offline, syncs to the NAS when reachable.",
  "main": "main.js",
  "author": "Juan Felipe Garcia",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.jfgarcia.codeman",
    "productName": "CodeMan",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": { "output": "dist" },
    "files": ["main.js", "config.js", "preload.js"],
    "extraResources": [
      {
        "from": "../codeman",
        "to": "codeman",
        "filter": [
          "**/*",
          "!structures/**",
          "!structures_pre_*/**",
          "!_codeman_backups/**",
          "!tests.html"
        ]
      }
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "extendInfo": {
        "NSLocalNetworkUsageDescription": "CodeMan connects to your NAS on the local network to load and save your snippets."
      }
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
